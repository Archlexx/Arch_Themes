{
  "name": "ArchPink",
  "type": "dark",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace": "#738cdd",
    "type": "#84CCB1",
    "class": "#F37DA8",
    "struct": "#F37DA8",
    "interface": "#EDB864",
    "enum": "#84CCB1",
    "typeParameter": "#465289",
    "parameter": "#465289",
    "variable": "#82CDDC",
    "property": "#AF84EE",
    "enumMember": "#AF84EE",
    "event": "#7082DB",
    "function": "#B3D47B",
    "method": "#B3D47B",
    "keyword": "#F37DA8",
    "modifier": "#AF84EE",
    "macro": "#D89DDF",
    "comment": "#A681DC",
    "string": "#D89DDF",
    "number": "#84CCB1",
    "regexp": "#84CCB1",
    "operator": "#EBA3CD",
    "constant": "#D89DDF",
    
    "declaration": {
      "namespace": "#82CDDC",
      "type": "#84CCB1",
      "class": "#F37DA8",
      "struct": "#F37DA8",
      "interface": "#EDB864",
      "enum": "#84CCB1",
      "typeParameter": "#465289",
      "function": "#B3D47B",
      "method": "#B3D47B",
      "macro": "#D89DDF",
      "variable": "#82CDDC",
      "property": "#AF84EE",
      "enumMember": "#AF84EE",
      "constant": "#D89DDF"
    },
    
    "deprecated": {
      "*": {
        "foreground": "#A681DC",
        "fontStyle": "strikethrough"
      }
    },
    
    "defaultLibrary": {
      "type": "#84CCB1",
      "class": "#F37DA8",
      "struct": "#F37DA8",
      "enum": "#84CCB1",
      "interface": "#84CCB1",
      "typeParameter": "#465289",
      "function": "#B3D47B",
      "method": "#B3D47B",
      "variable": "#82CDDC",
      "property": "#AF84EE"
    }
  },
  
  "tokenColors": [
    {
      "name": "JSON Keys",
      "scope": "support.type.property-name.json, meta.structure.dictionary.json > string.quoted.json",
      "settings": {
        "foreground": "#D89DDF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "JSON String Values",
      "scope": "meta.structure.dictionary.value.json > string.quoted.json, meta.structure.array.json > string.quoted.json, meta.structure.dictionary.value.json > string.quoted.double.json, meta.structure.array.json > string.quoted.double.json",
      "settings": {
        "foreground": "#D89DDF"
      }
    },
    {
      "name": "JSON Constants",
      "scope": "constant.language.json",
      "settings": {
        "foreground": "#82CDDC"
      }
    },
    {
      "name": "Comments",
      "scope": "comment, punctuation.definition.comment",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#A681DC"
      }
    },
    {
      "name": "Python Docstrings",
      "scope": "string.quoted.docstring.multi.python, string.quoted.docstring.single.python, string.quoted.docstring.raw.python",
      "settings": {
        "foreground": "#A681DC",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Python Docstring Punctuation",
      "scope": "string.quoted.docstring.multi.python punctuation.definition.string.begin, string.quoted.docstring.multi.python punctuation.definition.string.end, string.quoted.docstring.single.python punctuation.definition.string.begin, string.quoted.docstring.single.python punctuation.definition.string.end",
      "settings": {
        "foreground": "#A681DC",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Python F-string punctuation",
      "scope": "string.interpolated.python punctuation.definition.string.begin, string.interpolated.python punctuation.definition.string.end, meta.fstring.python punctuation.definition.string.begin, meta.fstring.python punctuation.definition.string.end",
      "settings": {
        "foreground": "#AF84EE"
      }
    },
    {
      "name": "Python F-string content",
      "scope": "string.interpolated.python, meta.fstring.python",
      "settings": {
        "foreground": "#AF84EE"
      }
    },
    {
      "name": "Strings general",
      "scope": "string -string.interpolated -string.quoted.docstring, punctuation.definition.string.begin -string.quoted.docstring, punctuation.definition.string.end -string.quoted.docstring",
      "settings": {
        "foreground": "#AF84EE"
      }
    },
    {
      "name": "String Escape",
      "scope": "constant.character.escape, constant.character.interpolation",
      "settings": {
        "foreground": "#EDB864"
      }
    },
    {
      "name": "Regular Expressions",
      "scope": "string.regexp, constant.other.symbol",
      "settings": {
        "foreground": "#84CCB1"
      }
    },
    {
      "name": "Constants",
      "scope": "constant.language, constant.other, support.constant, constant.numeric",
      "settings": {
        "foreground": "#D89DDF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keywords",
      "scope": "keyword, storage, storage.type, keyword.control, keyword.operator.new, keyword.operator.expression, keyword.other",
      "settings": {
        "foreground": "#F37DA8"
      }
    },
    {
      "name": "Operators",
      "scope": "keyword.operator, keyword.operator.arithmetic, keyword.operator.comparison, keyword.operator.logical, keyword.operator.assignment, keyword.operator.increment, keyword.operator.decrement",
      "settings": {
        "foreground": "#EBA3CD"
      }
    },
    {
      "name": "Functions",
      "scope": "entity.name.function, support.function, meta.function-call, meta.method-call, variable.function",
      "settings": {
        "foreground": "#B3D47B"
      }
    },
    {
      "name": "Classes",
      "scope": "entity.name.type.class, support.class, entity.name.class, entity.other.inherited-class",
      "settings": {
        "foreground": "#F37DA8"
      }
    },
    {
      "name": "Types",
      "scope": "entity.name.type, support.type, entity.name.type.interface, entity.name.type.enum, entity.name.type.struct, entity.name.type.type",
      "settings": {
        "foreground": "#F37DA8"
      }
    },
    {
      "name": "Namespaces",
      "scope": "entity.name.namespace, support.namespace, entity.name.module",
      "settings": {
        "foreground": "#82CDDC",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Variables",
      "scope": "variable, entity.name.variable, meta.definition.variable.name",
      "settings": {
        "foreground": "#82CDDC"
      }
    },
    {
      "name": "Parameters",
      "scope": "variable.parameter, meta.parameter",
      "settings": {
        "foreground": "#465289",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Properties",
      "scope": "variable.other.property, support.variable.property, meta.property.object, variable.object.property",
      "settings": {
        "foreground": "#AF84EE"
      }
    },
    {
      "name": "Fields",
      "scope": "variable.other.field, entity.name.variable.field, meta.field.declaration",
      "settings": {
        "foreground": "#AF84EE"
      }
    },
    {
      "name": "Enum Members",
      "scope": "variable.other.enummember, entity.name.variable.enum-member",
      "settings": {
        "foreground": "#84CCB1"
      }
    },
    {
      "name": "Events",
      "scope": "variable.other.event, meta.event.declaration",
      "settings": {
        "foreground": "#7082DB"
      }
    },
    {
      "name": "Tags",
      "scope": "entity.name.tag, punctuation.definition.tag, entity.name.tag.html, entity.name.tag.xml",
      "settings": {
        "foreground": "#B3D47B"
      }
    },
    {
      "name": "Attributes",
      "scope": "entity.other.attribute-name, support.type.property-name, entity.other.attribute-name.html, entity.other.attribute-name.xml",
      "settings": {
        "foreground": "#AF84EE"
      }
    },
    {
      "name": "IDs",
      "scope": "entity.other.attribute-name.id",
      "settings": {
        "foreground": "#7082DB"
      }
    },
    {
      "name": "Punctuation",
      "scope": "punctuation, punctuation.definition, punctuation.separator, punctuation.terminator, punctuation.accessor",
      "settings": {
        "foreground": "#EBA3CD"
      }
    },
    {
      "name": "Brackets",
      "scope": [
          "punctuation.section.brackets",
          "punctuation.definition.brackets",
          "meta.brace.square",
          "meta.brace.round",
          "meta.brace.curly",
          "punctuation.parenthesis",
          "punctuation.definition.parameters"
        ],
      "settings": {
        "foreground": "#F37DA8"
      }
    },
    {
      "name": "Template Expression",
      "scope": "punctuation.definition.template-expression, punctuation.section.embedded, punctuation.definition.interpolation",
      "settings": {
        "foreground": "#F37DA8"
      }
    },
    {
      "name": "Template Content",
      "scope": "meta.template.expression",
      "settings": {
        "foreground": "#82CDDC"
      }
    },
    {
      "name": "Units",
      "scope": "keyword.other.unit",
      "settings": {
        "foreground": "#84CCB1"
      }
    },
    {
      "name": "Invalid",
      "scope": "invalid, invalid.illegal, invalid.broken, invalid.unimplemented",
      "settings": {
        "foreground": "#F37DA8"
      }
    },
    {
      "name": "Deprecated",
      "scope": "invalid.deprecated",
      "settings": {
        "foreground": "#A681DC",
        "fontStyle": "strikethrough"
      }
    },
    {
      "name": "Diff Inserted",
      "scope": "markup.inserted.diff, meta.diff.header.to-file",
      "settings": {
        "foreground": "#84CCB1"
      }
    },
    {
      "name": "Diff Deleted",
      "scope": "markup.deleted.diff, meta.diff.header.from-file",
      "settings": {
        "foreground": "#F37DA8"
      }
    },
    {
      "name": "Diff Changed",
      "scope": "markup.changed.diff",
      "settings": {
        "foreground": "#84CCB1"
      }
    },
    {
      "name": "Diff Unchanged",
      "scope": "meta.diff.range, meta.diff.index",
      "settings": {
        "foreground": "#465289"
      }
    },
    {
      "name": "Info Tokens",
      "scope": "token.info-token",
      "settings": {
        "foreground": "#84CCB1"
      }
    },
    {
      "name": "Warn Tokens",
      "scope": "token.warn-token",
      "settings": {
        "foreground": "#AF84EE"
      }
    },
    {
      "name": "Error Tokens",
      "scope": "token.error-token",
      "settings": {
        "foreground": "#F37DA8"
      }
    },
    {
      "name": "Debug Tokens",
      "scope": "token.debug-token",
      "settings": {
        "foreground": "#84CCB1"
      }
    }
  ],
